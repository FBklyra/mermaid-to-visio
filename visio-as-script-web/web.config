<!--
  visio-as-script-web — static site for IIS.
  This app is 100% client-side: IIS only needs to serve these files. No Node,
  no application pool runtime, no installer.

  The one mandatory setting is the .mjs MIME mapping. IIS does not map .mjs by
  default, so it serves the Mermaid engine as application/octet-stream and the
  browser refuses it ("Failed to load module script: expected a JavaScript
  MIME type"). The mapping below fixes that.
-->
<configuration>
  <system.webServer>
    <staticContent>
      <!-- ES module engine (Mermaid). MUST be JavaScript or the app won't load. -->
      <remove fileExtension=".mjs" />
      <mimeMap fileExtension=".mjs" mimeType="text/javascript" />
      <!-- Source maps, if requested by devtools. Harmless if absent. -->
      <remove fileExtension=".map" />
      <mimeMap fileExtension=".map" mimeType="application/json" />
    </staticContent>

    <!-- Serve index.html for a request to the site root. -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!--
      OPTIONAL — compress the ~3 MB Mermaid engine on the wire (much faster first
      load). Requires the "Static Content Compression" IIS feature to be enabled
      on the server. Safe to leave in; ignored if the feature isn't installed.
    -->
    <httpCompression>
      <dynamicTypes>
        <add mimeType="text/javascript" enabled="true" />
      </dynamicTypes>
      <staticTypes>
        <add mimeType="text/javascript" enabled="true" />
      </staticTypes>
    </httpCompression>
    <urlCompression doStaticCompression="true" doDynamicCompression="false" />
  </system.webServer>
</configuration>
